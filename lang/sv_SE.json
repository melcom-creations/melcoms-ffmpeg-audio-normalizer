    "output_format_details": {
        "WAV": {
            "specs": "",
            "description": "Okomprimerad, förlustfri PCM-behållare. Mycket mångsidig för mastering, erbjuder nu helt anpassningsbart linjärt bitdjup, flyttalsalternativ och högupplösta samplingsfrekvenser."
        },
        "MP3": {
            "specs": "",
            "description": "Det mest universellt kompatibla förlustkomprimerade ljudformatet. Idealisk för allmän uppspelning på alla enheter, med nytillkommet stöd för anpassade konstanta (CBR) och mycket effektiva variabla (VBR) bithastigheter."
        },
        "FLAC": {
            "specs": "",
            "description": "Komprimerat förlustfritt format. Minskar filstorleken avsevärt utan någon försämring av ljudkvaliteten, och erbjuder nu uttrycklig kontroll över samplingsfrekvens och bitdjupsupplösning."
        },
        "M4A": {
            "specs": "",
            "description": "En modern MPEG-4 Audio-behållare. Erbjuder överlägsen komprimeringseffektivitet och ljudkvalitet jämfört med MP3 vid jämförbara bithastigheter, med fullständigt stöd för metadata-taggar och omslagsbilder."
        },
        "OGG": {
            "specs": "",
            "description": "En öppen källkod-behållare för förlustkomprimerat ljud. Mycket effektiv och transparent, med Vorbis-codec och nytillkommet stöd för högkvalitativ variabel (VBR) eller konstant (CBR) kodning."
        }
    },
