    "output_format_details": {
        "WAV": {
            "specs": "",
            "description": "Nieskompresowany, bezstratny kontener PCM. Niezwykle wszechstronny do masteringu, oferujący teraz w pełni konfigurowalną liniową głębię bitową, opcje zmiennoprzecinkowe i wysoką częstliwość próbkowania."
        },
        "MP3": {
            "specs": "",
            "description": "Najbardziej uniwersalny stratny format audio. Idealny do ogólnego odtwarzania na wszystkich urządzeniach, z nowo dodaną obsługą niestandardowych stałych (CBR) i zmiennych (VBR) przepływności."
        },
        "FLAC": {
            "specs": "",
            "description": "Skompresowany bezstratny format. Znacznie zmniejsza rozmiary plików bez utraty jakości dźwięku, oferując teraz wyraźną kontrolę nad częstotliwością próbkowania i głębią bitową."
        },
        "M4A": {
            "specs": "",
            "description": "Nowoczesny kontener MPEG-4 Audio. Oferuje lepszą wydajność kompresji i jakość dźwięku niż MP3 przy porównywalnych przepływnościach, z pełną obsługą metadanych oraz okładek albumów."
        },
        "OGG": {
            "specs": "",
            "description": "Otwarty stratny kontener multimedialny. Bardzo wydajny i przejrzysty, korzystający z kodeka Vorbis z nowo obsługiwanymi opcjami kodowania o wysokiej jakości zmiennej (VBR) lub stałej (CBR)."
        }
    },
